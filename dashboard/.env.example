# Copy this file to .env and fill in your values.

# Your laptop's local IP (find with `ifconfig` / `ip a` on Mac/Linux, `ipconfig` on Windows).
# Paste this IP into firmware/deskbuddy.ino as SERVER_URL so the ESP32 can reach the dashboard.
# LAPTOP_IP=192.168.1.100

# OpenAI API key — required for the /api/nudge endpoint.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
