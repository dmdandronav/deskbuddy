# Copy this file to .env

# Find your laptop's local IP with `ipconfig` (Windows) or `ifconfig`/`ip a`
# (Mac/Linux) — you'll need it for the ESP32 firmware's serverUrl too.
# This file itself doesn't need that IP, but...

# If you have a SECOND ESP32 running servo_controller.ino, put its IP here
# (find it by reading the Serial Monitor after it connects to wifi):
ESP32_SERVO_URL=http://192.168.1.55
